{
  "name": "hanafuda-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -F @hanafuda/frontend dev",
    "build": "pnpm -F @hanafuda/frontend build",
    "test": "pnpm -F @hanafuda/frontend test",
    "dev:backend": "pnpm -F @hanafuda/backend dev",
    "build:backend": "pnpm -F @hanafuda/backend build",
    "release": "deno run --allow-read --allow-write --allow-env --allow-run scripts/release-calver.ts"
  },
  "engines": {
    "node": ">=22.16.0"
  },
  "packageManager": "pnpm@10.5.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
