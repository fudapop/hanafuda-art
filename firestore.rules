rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /feedback/{document=**} {
      allow create: if true;
    }

    match /announcement_impressions/{document=**} {
      allow read, update, create: if true;
    }

    match /users/{userId} {
      // Users can read all if authenticated
      allow read: if request.auth != null;
      // User can create/update/delete only their own profile document
      allow write: if request.auth != null && userId == 'u_' + request.auth.uid;
    }

    // NEW: per-user game saves
    match /game_saves/{saveId} {
      // Only the owner can read their saves
      allow read: if request.auth != null
                  && resource.data.uid == request.auth.uid;

      // Only the owner can create/update their saves
      allow create, update: if request.auth != null
                            && request.resource.data.uid == request.auth.uid;

      // Only the owner can delete their saves
      // Prefer uid field, but fall back to document ID prefix for robustness
      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
    }

    // NEW: invite codes for multiplayer games
    match /invite_codes/{code} {
      // Anyone authenticated can read a code to validate it
      allow read: if request.auth != null;

      // Only creator can create their own codes
      allow create: if request.auth != null
                    && request.resource.data.createdBy == request.auth.uid
                    && request.resource.data.code is string
                    && request.resource.data.gameId is string
                    && request.resource.data.used == false;

      // Only allow marking as used when joining game
      allow update: if request.auth != null
                    && !resource.data.used  // Not already used
                    && request.resource.data.used == true  // Marking as used
                    && request.resource.data.usedBy == request.auth.uid;

      // Only creator can delete their unused codes
      allow delete: if request.auth != null
                    && resource.data.createdBy == request.auth.uid
                    && !resource.data.used;
    }

    // NEW: shared multiplayer game states
    match /multiplayer_games/{gameId} {
      // Helper function to check if user is a participant
      function isParticipant() {
        return request.auth.uid == resource.data.p1
            || request.auth.uid == resource.data.p2;
      }

      function isRequestParticipant() {
        return request.auth.uid == request.resource.data.p1
            || request.auth.uid == request.resource.data.p2;
      }

      // Helper to check if user is joining a waiting game
      function isJoiningWaitingGame() {
        return resource.data.status == 'waiting'
            && resource.data.p2 == ''
            && request.resource.data.p2 == request.auth.uid
            && request.resource.data.status == 'active';
      }

      // Participants can read their games
      allow read: if request.auth != null && (
        resource.data.status == 'waiting' || isParticipant());

      // Any authenticated user can create a game (matchmaking)
      allow create: if request.auth != null
                    && isRequestParticipant()
                    && request.resource.data.mode == 'multiplayer'
                    && request.resource.data.p1 is string
                    && request.resource.data.p2 is string
                    && request.resource.data.activePlayer is string
                    && request.resource.data.status is string;

      // Allow updates in two cases:
      // 1. Participant updating game state (client/enforced active player)
      // 2. Second player joining a waiting game
      allow update: if request.auth != null
                    && (
                      // Case 1: Participant making a move / updating game state
                      (isParticipant()
                        && request.resource.data.mode == 'multiplayer')
                      ||
                      // Case 2: Second player joining
                      isJoiningWaitingGame()
                    );

      // Participants can delete their games
      allow delete: if request.auth != null && isParticipant();
    }
  }
}

